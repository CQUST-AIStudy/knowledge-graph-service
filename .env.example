# 知识图谱服务配置
# 知识图谱服务配置

# 宿主机端口绑定
# 默认 0.0.0.0，供前端容器通过 host.docker.internal 访问。
KG_HOST_BIND=0.0.0.0
KG_HOST_PORT=10171

# 服务监听地址
KG_ADDR=:10171
# HTTP 读写超时
KG_READ_TIMEOUT=15s
KG_WRITE_TIMEOUT=30s
# CORS 允许的来源（* 表示全部）
KG_CORS_ORIGINS=*

# MySQL（远程）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ptadatabase
DB_USERNAME=root
DB_PASSWORD=
# 数据库是否必须（false 时无库也能启动）
KG_DB_REQUIRED=false
# 是否在默认图谱缺失或为空时自动导入数据结构课程种子数据
KG_SEED_ENABLED=true

# Redis（远程）
# 设为 true 启用缓存
KG_REDIS_ENABLED=false
KG_REDIS_ADDR=127.0.0.1:6379
KG_REDIS_PASSWORD=
KG_REDIS_DB=0
# 缓存 TTL（秒）
KG_CACHE_TTL=300s
